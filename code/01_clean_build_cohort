{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPi2zIZxU/d86FyX6y9dFuk"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["## STEP 1\n","\n","### Build ICU-Stay Cohort (ICUSTAYS + ADMISSIONS + PATIENTS → cohort_icustay.parquet)\n","\n"],"metadata":{"id":"4lGGGmZM6_RA"}},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive')\n","\n","DATA_DIR = \"/content/drive/MyDrive/mimic_data\"\n","OUT_DIR  = \"/content/drive/MyDrive/mimic_outputs\"\n","import os\n","os.makedirs(OUT_DIR, exist_ok=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"UyNqOyuUyp3K","executionInfo":{"status":"ok","timestamp":1772122602730,"user_tz":360,"elapsed":16525,"user":{"displayName":"JY CHEN","userId":"00820396203484511615"}},"outputId":"5ffa96a7-e1f0-46ec-b09c-84a87a038c94"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","execution_count":null,"metadata":{"id":"ZOGp5sTKPWjg"},"outputs":[],"source":["import pandas as pd\n","import numpy as np\n","from pathlib import Path\n","import os"]},{"cell_type":"code","source":["def compute_age_years_daylevel(intime: pd.Series, dob: pd.Series):\n","    \"\"\"\n","    Compute ICU age in years using day-level precision: (intime - dob) / 365.2425,\n","    which avoids pandas nanosecond overflow.\n","\n","    Note: In MIMIC-III, ages > 89 may appear as ~300 years due to de-identification.\n","    We top-code age at 90 and add an indicator age_ge_90.\n","\n","    Returns:\n","      age (float32 Series): age clipped at 90\n","      age_ge_90 (Int64 Series): 1 if raw age > 90 else 0 (missing stays <NA>)\n","    \"\"\"\n","    intime = pd.to_datetime(intime, errors=\"coerce\")\n","    dob = pd.to_datetime(dob, errors=\"coerce\")\n","\n","    intime_d = intime.values.astype(\"datetime64[D]\")\n","    dob_d = dob.values.astype(\"datetime64[D]\")\n","\n","    days = (intime_d - dob_d).astype(\"timedelta64[D]\").astype(\"float64\")\n","    age_raw = days / 365.2425\n","\n","    # Convert clearly invalid negative ages to NaN\n","    age_raw = np.where(age_raw < 0, np.nan, age_raw)\n","\n","    # Create flag in numpy first (0/1), then convert to pandas Int64\n","    age_ge_90_np = np.where(np.isnan(age_raw), np.nan, (age_raw > 90).astype(np.int64))\n","\n","    # Top-code age at 90\n","    age = np.where(age_raw > 90, 90, age_raw)\n","\n","    age = pd.Series(age, index=intime.index, dtype=\"float32\")\n","    age_ge_90 = pd.Series(age_ge_90_np, index=intime.index, dtype=\"Int64\")\n","    return age, age_ge_90\n","\n","def build_cohort_icustay(data_dir: str, out_dir: str) -> str:\n","    icu = pd.read_csv(\n","        os.path.join(data_dir, \"ICUSTAYS.csv\"),\n","        usecols=[\"ICUSTAY_ID\", \"SUBJECT_ID\", \"HADM_ID\", \"INTIME\", \"OUTTIME\"],\n","    )\n","    adm = pd.read_csv(\n","        os.path.join(data_dir, \"ADMISSIONS.csv\"),\n","        usecols=[\n","            \"HADM_ID\", \"HOSPITAL_EXPIRE_FLAG\",\n","            \"ADMISSION_TYPE\", \"ADMISSION_LOCATION\",\n","            \"INSURANCE\", \"LANGUAGE\", \"RELIGION\",\n","            \"MARITAL_STATUS\", \"ETHNICITY\",\n","        ],\n","    )\n","    pat = pd.read_csv(\n","        os.path.join(data_dir, \"PATIENTS.csv\"),\n","        usecols=[\"SUBJECT_ID\", \"GENDER\", \"DOB\"],\n","    )\n","\n","    icu.columns = icu.columns.str.lower()\n","    adm.columns = adm.columns.str.lower()\n","    pat.columns = pat.columns.str.lower()\n","\n","    icu[\"intime\"] = pd.to_datetime(icu[\"intime\"], errors=\"coerce\")\n","    icu[\"outtime\"] = pd.to_datetime(icu[\"outtime\"], errors=\"coerce\")\n","    pat[\"dob\"] = pd.to_datetime(pat[\"dob\"], errors=\"coerce\")\n","\n","    cohort = (\n","        icu.merge(adm, on=\"hadm_id\", how=\"left\", validate=\"many_to_one\")\n","           .merge(pat, on=\"subject_id\", how=\"left\", validate=\"many_to_one\")\n","    )\n","\n","    cohort[\"hospital_expired\"] = cohort[\"hospital_expire_flag\"].astype(\"Int64\")\n","    cohort[\"icu_age\"], cohort[\"age_ge_90\"] = compute_age_years_daylevel(cohort[\"intime\"], cohort[\"dob\"])\n","\n","    cohort = cohort.dropna(subset=[\"icustay_id\", \"subject_id\", \"hadm_id\", \"intime\", \"hospital_expired\"])\n","\n","    keep_cols = [\n","        \"icustay_id\", \"hadm_id\", \"subject_id\", \"intime\", \"outtime\",\n","        \"hospital_expired\", \"icu_age\", \"age_ge_90\", \"gender\",\n","        \"insurance\", \"language\", \"religion\", \"marital_status\", \"ethnicity\",\n","        \"admission_type\", \"admission_location\",\n","    ]\n","    cohort = cohort[keep_cols]\n","\n","    out_path = os.path.join(out_dir, \"cohort_icustay.parquet\")\n","    cohort.to_parquet(out_path, index=False)\n","    return out_path\n","\n","cohort_path = build_cohort_icustay(DATA_DIR, OUT_DIR)\n","print(\"✅ Saved:\", cohort_path)\n","\n","# sanity check\n","cohort = pd.read_parquet(cohort_path)\n","print(\"rows:\", len(cohort))\n","print(\"unique icustay_id:\", cohort[\"icustay_id\"].nunique())\n","print(\"mortality rate:\", float(cohort[\"hospital_expired\"].mean()))\n","print(\"icu_age max:\", float(cohort[\"icu_age\"].max()))\n","print(\"age_ge_90 rate:\", float(cohort[\"age_ge_90\"].mean()))\n","print(\"icu_age missing rate:\", float(cohort[\"icu_age\"].isna().mean()))\n","cohort.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":521},"id":"8zabjX4RwpN4","executionInfo":{"status":"ok","timestamp":1772122982671,"user_tz":360,"elapsed":1160,"user":{"displayName":"JY CHEN","userId":"00820396203484511615"}},"outputId":"54608fd1-3646-41fb-a656-e0fa5f81d9d5"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Saved: /content/drive/MyDrive/mimic_outputs/cohort_icustay.parquet\n","rows: 61532\n","unique icustay_id: 61532\n","mo